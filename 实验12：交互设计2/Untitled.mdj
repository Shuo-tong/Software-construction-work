								{
									"_type": "UMLOperation",
									"_id": "AAAAAAGehzGZ/vXOgCA=",
									"_parent": {
										"$ref": "AAAAAAGehzGZ/vXKCHM="
									},
									"name": "idx",
									"documentation": "上三角索引：要求 1 <= i <= j <= N。\n第 i 行起始偏移 = (i-1)\n(N+1) - (i-1)\ni/2，列偏移 = j - i。",
									"visibility": "private",
									"parameters": [
										{
											"_type": "UMLParameter",
											"_id": "AAAAAAGehzGZ/vXPx90=",
											"_parent": {
												"$ref": "AAAAAAGehzGZ/vXOgCA="
											},
											"name": "i",
											"type": "int"
										},
										{
