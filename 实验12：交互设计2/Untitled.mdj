							],
							"documentation": "乘除法共享数据基（MultiplicativeBase）。\n设计要点：\n1) 操作数范围 [1, N]（N=10），仅存储上三角 1 <= i <= j <= N，共 N\n(N+1)/2 = 55 项。\n2) 乘法直接读表；除法用\"反向查表\"思路：在第 b 行查值为 a 的列号即商 q，\n即同一份数据同时服务乘法与除法两种运算。",
							"attributes": [
								{
									"_type": "UMLAttribute",
									"_id": "AAAAAAGehzGaJvck+oc=",
									"_parent": {
										"$ref": "AAAAAAGehzGZ/vXKCHM="
									},
									"name": "N",
									"isStatic": true,
									"isLeaf": true,
									"type": "int",
									"isReadOnly": true,
									"defaultValue": "10"
								},
								{
									"_type": "UMLAttribute",
									"_id": "AAAAAAGehzGaJvcpydg=",
									"_parent": {
										"$ref": "AAAAAAGehzGZ/vXKCHM="
									},
									"name": "table",
									"visibility": "private",
									"isLeaf": true,
									"type": "int",
									"multiplicity": "*",
									"isReadOnly": true
								}
							],
							"operations": [
								{
									"_type": "UMLOperation",
									"_id": "AAAAAAGehzGZ/vXLmks=",
									"_parent": {
										"$ref": "AAAAAAGehzGZ/vXKCHM="
									},
									"name": "MultiplicativeBase",
									"stereotype": "constructor",
									"visibility": "private"
								},
								{
									"_type": "UMLOperation",
									"_id": "AAAAAAGehzGZ/vXMNMc=",
									"_parent": {
										"$ref": "AAAAAAGehzGZ/vXKCHM="
									},
									"name": "getInstance",
									"documentation": "获取单例。",
									"isStatic": true,
									"parameters": [
										{
											"_type": "UMLParameter",
											"_id": "AAAAAAGehzGZ/vXNPGY=",
											"_parent": {
												"$ref": "AAAAAAGehzGZ/vXMNMc="
											},
											"type": {
												"$ref": "AAAAAAGehzGZ/vXLmks="
